# Copy to .env and fill in. NEVER commit .env.
OPENAI_API_KEY=sk-your-key-here

# Models (override if you want)
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# Chroma persistence
CHROMA_DIR=./chroma_db
CHROMA_COLLECTION=enterprise_docs

# Graph checkpointer
CHECKPOINT_DIR=./checkpoints

# Logging
LOG_LEVEL=INFO

# Optional: Tavily web search (Phase 5). Get a key at tavily.com
# TAVILY_API_KEY=tvly-your-key-here

# Optional: LangSmith tracing (Phase 6). Get a key at smith.langchain.com
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=ls-your-key-here
# LANGSMITH_PROJECT=enterprise-rag-assistant
